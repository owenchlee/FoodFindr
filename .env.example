PORT=3000

# Google Cloud Console — browser-restricted key (Maps JavaScript API only)
GOOGLE_MAPS_BROWSER_KEY=your_browser_restricted_maps_js_key

# Google Cloud Console — Map ID with a dark style configured (needed for AdvancedMarkerElement)
GOOGLE_MAPS_MAP_ID=your_map_id

# Google Cloud Console — server-only key (never sent to the browser).
# API restrictions on this key must include both Places API and Geocoding API.
GOOGLE_PLACES_SERVER_KEY=your_ip_restricted_places_key

# Anthropic Console — API key
ANTHROPIC_API_KEY=your_anthropic_api_key
